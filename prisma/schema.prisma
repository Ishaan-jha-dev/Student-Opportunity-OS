// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Opportunity {
  id          String   @id @default(uuid())
  title       String
  company     String
  type        String   // "internship" or "competition"
  domain      String[] // e.g., ["Finance", "Marketing"]
  deadline    DateTime
  difficulty  Difficulty
  description String
  eligibility String
  apply_link  String
  stipend     String?
  created_at  DateTime @default(now())
}
